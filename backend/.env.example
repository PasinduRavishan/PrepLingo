# ============================================================
# PrepLingo — Environment Variables Template
# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# cp .env.example .env
# NEVER commit .env to Git (it contains secrets)
# ============================================================

# --- Groq API Key (REQUIRED) ---
# Get yours free at: https://console.groq.com/keys
# Powers the Llama 3.1 8B LLM for question generation and evaluation
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# --- Groq Models ---
# Primary: best quality — used for all LLM calls by default
GROQ_MODEL=llama-3.3-70b-versatile
# Fallback: fast, lightweight — auto-activated transparently on rate limit (HTTP 429)
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# --- Google API Key (OPTIONAL) ---
# Only needed if you use Gemini for resume parsing LLM
# Embeddings now use local BAAI/bge-base-en-v1.5 — no Google API needed
# GOOGLE_API_KEY=AIza_YOUR_KEY_HERE

# --- Embedding Model ---
# DO NOT change this after ingesting the knowledge base into ChromaDB.
# Changing embedding models requires deleting vector_store_data/ and re-ingesting.
# BAAI/bge-base-en-v1.5: 768 dims, MTEB 72.3, local (no API, no rate limits)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# --- Database ---
# SQLite for development — stored as a local file, zero setup
# For production swap to: postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///./preplingo.db

# --- Auth (JWT) --- deferred to Phase 6
# Secret key used to sign auth tokens — use any random string for dev
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Vector Store ---
# Where ChromaDB saves the embedded documents on disk
VECTOR_STORE_PATH=./vector_store_data

# --- App ---
APP_ENV=development
